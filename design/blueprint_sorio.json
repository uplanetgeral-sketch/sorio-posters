  "slot_grid": {
    "description": "10 slots de output por item, distribuídos pelas famílias",
    "standard_distribution": [
      {"slot": "F01_A", "family": "F01", "variant_hint": "hero macro close-up"},
      {"slot": "F01_B", "family": "F01", "variant_hint": "hero 45 graus"},
      {"slot": "F02_A", "family": "F02", "variant_hint": "overlay dark bottom + display nome"},
      {"slot": "F02_B", "family": "F02", "variant_hint": "flat color panel + claim monumental"},
      {"slot": "F03_A", "family": "F03", "variant_hint": "motion splash full bleed"},
      {"slot": "F03_B", "family": "F03", "variant_hint": "ingredientes suspensos"},
      {"slot": "F05a_A", "family": "F05a", "variant_hint": "flat-lay cenital grid"},
      {"slot": "F05a_B", "family": "F05a", "variant_hint": "single hero grid label"},
      {"slot": "F05b_A", "family": "F05b", "variant_hint": "info graphic fundo linho"},
      {"slot": "F05b_B", "family": "F05b", "variant_hint": "pairing chart fundo off-white"}
    ],
    "note": "F04 excluído por requerer fotografia própria não-AI"
  },

  "decision_rules": {
    "family_selection_by_category": {
      "PRATO": ["F01", "F02", "F03", "F05a", "F05b"],
      "BEBIDA": ["F01", "F02", "F03", "F05b"]
    },
    "selo_selection_logic": {
      "if_cocktail_and_evening": "ritual-dourado",
      "if_cocktail_and_golden_hour": "sunset-dourado",
      "if_peixe_do_dia": "pico-dourado",
      "if_chef_special": "mesa-creme",
      "if_full_menu_or_partilha": "para_a_mesa-creme",
      "if_storytelling_or_brand_voice": "rio-says-verde",
      "fallback_PRATO": "mesa-creme",
      "fallback_BEBIDA": "ritual-dourado"
    },
    "claim_selection_logic": {
      "respect_claim_master": "Verão Sem Pressa — só usar directamente em F02 quando for claim standalone. Quando selo já contém, não duplicar.",
      "by_context_priority": [
        "specific_moment (golden_hour, lunch, sunset, evening) > ",
        "specific_feature (chef_special, peixe_do_dia) > ",
        "generic_category (PRATO, BEBIDA)"
      ],
      "length_by_family": {
        "F02": "1-3 palavras preferencial (claim manifesto)",
        "F01": "até 5 palavras",
        "F03": "até 4 palavras",
        "F05a": "até 5 palavras",
        "F05b": "até 6 palavras"
      }
    },
    "hero_image_handling": {
      "AI_generated_hero": "usar Placid Media upload para obter URL pública, passar como hero_url param",
      "client_photo": "URL direto do cliente (Drive, Drop)",
      "F04_exclusive": "Sempre foto própria cliente, nunca AI"
    },
    "accent_italic_selection": {
      "respect_category_tone": "BEBIDA tem accent com 'rio'/'hora dourada'; PRATO tem accent com 'terra'/'mesa'",
      "avoid_duplication_with_selo": "Se selo = ritual (contém 'Verão Sem Pressa'), accent NÃO repete 'Verão Sem Pressa'"
    },
    "location_cta": {
      "default": "VALADA DO RIBATEJO · SORIO.PT",
      "short": "SORIO.PT",
      "event_variant": "VALADA DO RIBATEJO · {data} · SORIO.PT"
    }
  },

  "template_urls": {
    "base": "https://sorio-posters.example.netlify.app/",
    "by_family": {
      "f01": "{base}f01.html",
      "f02": "{base}f02.html",
      "f03": "{base}f03.html",
      "f05a": "{base}f05a.html",
      "f05b": "{base}f05b.html"
    },
    "params_schema": {
      "required_all_families": ["nome", "ingredientes", "claim", "selo", "location", "hero"],
      "family_specific": {
        "f05a": ["grid_items[]"],
        "f05b": ["meta_pairs[]", "background_variant"]
      }
    }
  },

